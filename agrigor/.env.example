PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

MONGO_URI=mongodb://127.0.0.1:27017/agrigor

SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
SESSION_NAME=agrigor.sid

JWT_SECRET=REPLACE_WITH_DIFFERENT_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=REPLACE_WITH_EMAIL
EMAIL_PASS=REPLACE_WITH_APP_PASSWORD
EMAIL_FROM="Agrigor <no-reply@agrigor.com>"
